{
  "manifest": {
    "id": "love-notes",
    "name": "Love Notes",
    "version": "1.0.0",
    "description": "A private inbox for leaving short notes, compliments, or reminders for your partner.",
    "entrypoint": "index.html",
    "runtime": "static",
    "category": "couple",
    "tags": [
      "couples"
    ],
    "data_access": {
      "reads": [
        "family.members"
      ],
      "writes": []
    },
    "permissions": {
      "default_audience": "adults",
      "requires_approval": false
    },
    "storage": "db",
    "icon": "💌",
    "nav": {
      "label": "Love Notes"
    }
  },
  "migrations": [
    {
      "version": 1,
      "sql": "CREATE TABLE IF NOT EXISTS partner_config (\n  member_id TEXT NOT NULL,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  partner_id TEXT NOT NULL,\n  PRIMARY KEY (member_id, household_id)\n);\n\nCREATE TABLE IF NOT EXISTS notes (\n  id TEXT PRIMARY KEY,\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  sender_id TEXT NOT NULL,\n  recipient_id TEXT NOT NULL,\n  content TEXT NOT NULL,\n  sent_at TEXT NOT NULL,\n  read_at TEXT\n);"
    }
  ],
  "files": {
    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <base href=\"/run/love-notes/\" />\n  <title>Love Notes</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: var(--hub-font, system-ui, sans-serif);\n      font-size: var(--hub-font-size, 15px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      min-height: 100vh;\n    }\n\n    .view { display: none; }\n    .view.active { display: block; }\n\n    /* ── App header ── */\n    .app-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 16px 20px 0;\n    }\n    .app-header-left { display: flex; align-items: center; gap: 8px; }\n    .app-header .icon { font-size: 1.3rem; }\n    .app-header h1 { font-size: 1.25rem; font-weight: 700; }\n\n    /* ── Setup view ── */\n    .setup-wrap {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      padding: 48px 20px;\n      min-height: 80vh;\n      justify-content: center;\n    }\n    .setup-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 32px;\n      max-width: 420px;\n      width: 100%;\n      text-align: center;\n    }\n    .setup-icon { font-size: 2.5rem; margin-bottom: 16px; }\n    .setup-card h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 6px; }\n    .setup-card .setup-desc { color: var(--hub-text-muted, #6b7280); font-size: 0.9rem; margin-bottom: 24px; }\n    .setup-card .pick-label { font-weight: 600; margin-bottom: 12px; text-align: left; display: block; }\n    .member-list { margin-bottom: 20px; }\n\n    .member-option {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      padding: 10px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      cursor: pointer;\n      margin-bottom: 6px;\n      transition: border-color .15s, background .15s;\n      text-align: left;\n    }\n    .member-option input[type=\"radio\"] { accent-color: var(--hub-primary, #6366f1); }\n    .member-option:has(input:checked) {\n      border-color: var(--hub-primary, #6366f1);\n      background: color-mix(in srgb, var(--hub-primary, #6366f1) 6%, transparent);\n    }\n    .member-avatar {\n      width: 32px; height: 32px; border-radius: 50%;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 0.8rem; font-weight: 700; color: #fff; flex-shrink: 0;\n    }\n    .member-name { font-weight: 500; font-size: 0.95rem; }\n\n    /* ── Main content ── */\n    .content { padding: 12px 20px 20px; max-width: 600px; }\n\n    .partner-bar {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      margin-bottom: 14px;\n      color: var(--hub-text-muted, #6b7280);\n      font-size: 0.85rem;\n    }\n    .partner-bar .partner-avatar { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 700; color: #fff; flex-shrink: 0; }\n    .partner-bar .partner-name { font-weight: 600; color: var(--hub-text, #111827); }\n\n    /* ── Notes list ── */\n    .notes-list { display: flex; flex-direction: column; gap: 10px; }\n\n    .note-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 14px 16px;\n    }\n    .note-card.unread {\n      border-left: 3px solid var(--hub-primary, #6366f1);\n      background: color-mix(in srgb, var(--hub-primary, #6366f1) 4%, var(--hub-surface, #fff));\n    }\n    .note-meta {\n      display: flex; align-items: center; gap: 8px; margin-bottom: 8px;\n    }\n    .note-meta .note-avatar { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: #fff; flex-shrink: 0; }\n    .note-meta .note-sender { font-weight: 600; font-size: 0.875rem; }\n    .note-meta .unread-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--hub-primary, #6366f1); flex-shrink: 0; }\n    .note-meta .note-time { margin-left: auto; font-size: 0.8rem; color: var(--hub-text-muted, #6b7280); white-space: nowrap; }\n    .note-content { font-size: 0.95rem; line-height: 1.55; white-space: pre-wrap; word-break: break-word; }\n\n    /* ── Empty state ── */\n    .empty-state {\n      text-align: center; padding: 48px 20px; color: var(--hub-text-muted, #6b7280);\n    }\n    .empty-state .empty-icon { font-size: 2rem; margin-bottom: 12px; }\n    .empty-state p { font-size: 0.95rem; }\n\n    /* ── Buttons ── */\n    .btn-primary {\n      background: var(--hub-primary, #6366f1);\n      color: var(--hub-primary-fg, #fff);\n      border: none;\n      border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px;\n      font-size: 0.95rem; font-weight: 600; cursor: pointer;\n      transition: opacity .15s;\n      display: inline-flex; align-items: center; gap: 6px;\n    }\n    .btn-primary:hover:not(:disabled) { opacity: .85; }\n    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }\n    .btn-secondary {\n      background: transparent; color: var(--hub-text, #111827);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      padding: 10px 20px; font-size: 0.95rem; font-weight: 500; cursor: pointer;\n    }\n    .btn-secondary:hover { background: var(--hub-bg, #f9fafb); }\n    .btn-icon {\n      background: transparent; border: none; cursor: pointer;\n      color: var(--hub-text-muted, #6b7280);\n      padding: 6px; border-radius: var(--hub-radius, 4px);\n      font-size: 1rem; line-height: 1;\n    }\n    .btn-icon:hover { color: var(--hub-text, #111827); background: var(--hub-bg, #f9fafb); }\n\n    /* ── Modal ── */\n    .modal-backdrop {\n      position: fixed; inset: 0;\n      background: rgba(0,0,0,.45);\n      display: flex; align-items: center; justify-content: center;\n      z-index: 1000; padding: 20px;\n    }\n    .modal {\n      background: var(--hub-surface, #fff);\n      border-radius: var(--hub-radius, 8px);\n      padding: 24px; width: 100%; max-width: 440px;\n      box-shadow: 0 8px 32px rgba(0,0,0,.18);\n    }\n    .modal h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 16px; }\n    .modal textarea {\n      width: 100%; padding: 10px 12px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      font-family: inherit; font-size: inherit;\n      resize: vertical; min-height: 130px;\n    }\n    .modal textarea:focus { outline: 2px solid var(--hub-primary, #6366f1); outline-offset: 1px; }\n    .char-count { font-size: 0.8rem; color: var(--hub-text-muted, #6b7280); text-align: right; margin: 4px 0 16px; }\n    .char-count.over { color: #ef4444; }\n    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; }\n  </style>\n</head>\n<body>\n\n  <!-- ── Setup view ── -->\n  <div id=\"view-setup\" class=\"view\">\n    <div class=\"setup-wrap\">\n      <div class=\"setup-card\">\n        <div class=\"setup-icon\">💌</div>\n        <h2>Love Notes</h2>\n        <p class=\"setup-desc\">Leave sweet notes for your partner. Only the two of you will see them.</p>\n        <span class=\"pick-label\">Who is your partner?</span>\n        <div id=\"setup-members\" class=\"member-list\"></div>\n        <button class=\"btn-primary\" style=\"width:100%;justify-content:center\" onclick=\"savePartner()\">Get Started</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- ── Main view ── -->\n  <div id=\"view-main\" class=\"view\">\n    <div class=\"app-header\">\n      <div class=\"app-header-left\">\n        <span class=\"icon\">💌</span>\n        <h1>Love Notes</h1>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:8px\">\n        <button class=\"btn-icon\" title=\"Change partner\" onclick=\"showSetup()\">⚙️</button>\n        <button class=\"btn-primary\" onclick=\"openCompose()\">✏️ Write a Note</button>\n      </div>\n    </div>\n    <div class=\"content\">\n      <div id=\"partner-bar\" class=\"partner-bar\"></div>\n      <div id=\"notes-list\" class=\"notes-list\"></div>\n    </div>\n  </div>\n\n  <script type=\"module\">\n    import { esc, initial, memberColor, formatRelativeDate } from \"/hub-sdk.js\";\n    import { validateNote } from \"./logic.js\";\n\n    const CONTEXT = window.__CONTEXT_URL ?? \"\";\n    const DB      = window.__DB_URL      ?? \"\";\n    const ME      = window.__CURRENT_MEMBER ?? null;\n    const APP_ID  = window.__APP_ID ?? \"love-notes\";\n\n    let members = [];\n    let partner = null;\n    let notes   = [];\n    let modalEl = null;\n\n    // ── DB helper ─────────────────────────────────────────────────────────────\n    async function db(sql, params = []) {\n      if (!DB) return { rows: [] };\n      const res = await fetch(DB, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ sql, params }),\n      });\n      return res.json();\n    }\n\n    // ── Data loading ──────────────────────────────────────────────────────────\n    async function loadMembers() {\n      if (!CONTEXT) {\n        members = [\n          { id: \"demo-1\", name: \"Alex\",   role: \"adult\" },\n          { id: \"demo-2\", name: \"Jordan\", role: \"adult\" },\n          { id: \"demo-3\", name: \"Sam\",    role: \"adult\" },\n        ];\n        return;\n      }\n      try {\n        const res = await fetch(`${CONTEXT}?keys=family.members`);\n        members = ((await res.json())[\"family.members\"]) ?? [];\n      } catch { members = []; }\n    }\n\n    async function loadPartner() {\n      if (!ME) return null;\n      const { rows } = await db(\n        \"SELECT partner_id FROM partner_config WHERE member_id = ?\",\n        [ME.id]\n      );\n      return rows.length ? (members.find(m => m.id === rows[0].partner_id) ?? null) : null;\n    }\n\n    async function loadNotes() {\n      if (!ME) {\n        notes = [\n          { id: \"d1\", sender_id: \"demo-2\", recipient_id: \"demo-1\", content: \"Good morning! Have a wonderful day ☀️\",     sent_at: new Date(Date.now() - 3_600_000).toISOString(), read_at: new Date().toISOString() },\n          { id: \"d2\", sender_id: \"demo-2\", recipient_id: \"demo-1\", content: \"Don't forget we have dinner plans at 7 :)\", sent_at: new Date(Date.now() - 7_200_000).toISOString(), read_at: null },\n        ];\n        return;\n      }\n      const { rows } = await db(\n        \"SELECT * FROM notes WHERE recipient_id = ? ORDER BY sent_at DESC\",\n        [ME.id]\n      );\n      notes = rows;\n    }\n\n    async function markUnreadAsRead() {\n      if (!ME || !notes.some(n => !n.read_at)) return;\n      const now = new Date().toISOString();\n      await db(\n        \"UPDATE notes SET read_at = ? WHERE recipient_id = ? AND read_at IS NULL\",\n        [now, ME.id]\n      );\n      notes = notes.map(n => n.read_at ? n : { ...n, read_at: now });\n    }\n\n    // ── Partner save ──────────────────────────────────────────────────────────\n    window.savePartner = async function() {\n      const sel = document.querySelector('#setup-members input[type=\"radio\"]:checked');\n      if (!sel) return;\n      const partnerId = sel.value;\n\n      const btn = document.querySelector('#view-setup .btn-primary');\n      if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n\n      try {\n        if (ME) {\n          await db(\n            `INSERT INTO partner_config (member_id, partner_id) VALUES (?, ?)\n             ON CONFLICT (member_id, household_id) DO UPDATE SET partner_id = EXCLUDED.partner_id`,\n            [ME.id, partnerId]\n          );\n        }\n        partner = members.find(m => m.id === partnerId) ?? null;\n        await loadNotes();\n        showMain();\n        markUnreadAsRead();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Get Started\"; }\n        throw e;\n      }\n    };\n\n    // ── Modal helpers ─────────────────────────────────────────────────────────\n    function openModal(html) {\n      closeModal();\n      modalEl = document.createElement(\"div\");\n      modalEl.className = \"modal-backdrop\";\n      modalEl.innerHTML = `<div class=\"modal\">${html}</div>`;\n      modalEl.addEventListener(\"click\", e => { if (e.target === modalEl) closeModal(); });\n      document.body.appendChild(modalEl);\n    }\n    function closeModal() { modalEl?.remove(); modalEl = null; }\n\n    // ── Compose ───────────────────────────────────────────────────────────────\n    window.openCompose = function() {\n      openModal(`\n        <h3>Note to ${esc(partner?.name ?? \"your partner\")}</h3>\n        <textarea id=\"compose-text\" placeholder=\"Write something sweet…\" oninput=\"updateCharCount()\"></textarea>\n        <div id=\"char-count\" class=\"char-count\">0 / 500</div>\n        <div class=\"modal-actions\">\n          <button class=\"btn-secondary\" onclick=\"closeModal()\">Cancel</button>\n          <button class=\"btn-primary\" onclick=\"sendNote()\">Send 💌</button>\n        </div>\n      `);\n      document.getElementById(\"compose-text\").focus();\n    };\n\n    window.updateCharCount = function() {\n      const ta = document.getElementById(\"compose-text\");\n      const el = document.getElementById(\"char-count\");\n      if (!ta || !el) return;\n      const len = ta.value.length;\n      el.textContent = `${len} / 500`;\n      el.classList.toggle(\"over\", len > 500);\n    };\n\n    window.sendNote = async function() {\n      const ta = document.getElementById(\"compose-text\");\n      if (!ta) return;\n      const result = validateNote(ta.value);\n      if (!result.valid) { ta.focus(); return; }\n\n      const btn = modalEl?.querySelector(\".modal-actions .btn-primary\");\n      if (btn) { btn.disabled = true; btn.textContent = \"Sending…\"; }\n\n      try {\n        if (ME && partner) {\n          await db(\n            \"INSERT INTO notes (id, sender_id, recipient_id, content, sent_at) VALUES (?, ?, ?, ?, ?)\",\n            [crypto.randomUUID(), ME.id, partner.id, result.trimmed, new Date().toISOString()]\n          );\n          fetch(\"/api/notifications/send\", {\n            method: \"POST\",\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify({ title: \"New Love Note 💌\", body: `${ME.name} left you a note`, url: `/run/${APP_ID}` }),\n          }).catch(() => {});\n        }\n        closeModal();\n      } catch(e) {\n        if (btn) { btn.disabled = false; btn.textContent = \"Send 💌\"; }\n        throw e;\n      }\n    };\n\n    window.closeModal = closeModal;\n\n    // ── Views ─────────────────────────────────────────────────────────────────\n    window.showSetup = function() {\n      const otherAdults = members.filter(m => m.role === \"adult\" && m.id !== (ME?.id ?? \"demo-1\"));\n      const listEl = document.getElementById(\"setup-members\");\n      listEl.innerHTML = otherAdults.map(m => {\n        const color = memberColor(m.id, members);\n        return `\n          <label class=\"member-option\">\n            <input type=\"radio\" name=\"partner\" value=\"${esc(m.id)}\" />\n            <span class=\"member-avatar\" style=\"background:${color}\">${esc(initial(m.name))}</span>\n            <span class=\"member-name\">${esc(m.name)}</span>\n          </label>`;\n      }).join(\"\");\n      if (partner) {\n        const radio = listEl.querySelector(`input[value=\"${CSS.escape(partner.id)}\"]`);\n        if (radio) radio.checked = true;\n      }\n      document.getElementById(\"view-setup\").classList.add(\"active\");\n      document.getElementById(\"view-main\").classList.remove(\"active\");\n    };\n\n    function showMain() {\n      document.getElementById(\"view-setup\").classList.remove(\"active\");\n      document.getElementById(\"view-main\").classList.add(\"active\");\n      render();\n    }\n\n    function render() {\n      const partnerBarEl = document.getElementById(\"partner-bar\");\n      if (partner) {\n        const color = memberColor(partner.id, members);\n        partnerBarEl.innerHTML = `\n          <span class=\"partner-avatar\" style=\"background:${color}\">${esc(initial(partner.name))}</span>\n          Notes from <span class=\"partner-name\">${esc(partner.name)}</span>`;\n      } else {\n        partnerBarEl.innerHTML = \"\";\n      }\n\n      const listEl = document.getElementById(\"notes-list\");\n      if (!notes.length) {\n        listEl.innerHTML = `\n          <div class=\"empty-state\">\n            <div class=\"empty-icon\">💌</div>\n            <p>No notes yet — write the first one for ${esc(partner?.name ?? \"your partner\")}.</p>\n          </div>`;\n        return;\n      }\n\n      const memberMap = Object.fromEntries(members.map(m => [m.id, m]));\n      listEl.innerHTML = notes.map(n => {\n        const sender = memberMap[n.sender_id] ?? { id: n.sender_id, name: \"Someone\" };\n        const color  = memberColor(sender.id, members);\n        const unread = !n.read_at;\n        return `\n          <div class=\"note-card${unread ? \" unread\" : \"\"}\">\n            <div class=\"note-meta\">\n              <span class=\"note-avatar\" style=\"background:${color}\">${esc(initial(sender.name))}</span>\n              <span class=\"note-sender\">${esc(sender.name)}</span>\n              ${unread ? '<span class=\"unread-dot\"></span>' : \"\"}\n              <span class=\"note-time\">${formatRelativeDate(n.sent_at)}</span>\n            </div>\n            <div class=\"note-content\">${esc(n.content)}</div>\n          </div>`;\n      }).join(\"\");\n    }\n\n    // ── Init ──────────────────────────────────────────────────────────────────\n    (async () => {\n      await loadMembers();\n      partner = await loadPartner();\n      if (!partner) {\n        window.showSetup();\n      } else {\n        await loadNotes();\n        showMain();\n        markUnreadAsRead();\n      }\n    })();\n  </script>\n</body>\n</html>\n",
    "logic.js": "const MAX_LENGTH = 500;\n\nexport function validateNote(content) {\n  const trimmed = (content ?? \"\").trim();\n  if (!trimmed) return { valid: false, message: \"Note cannot be empty.\", trimmed: \"\" };\n  if (trimmed.length > MAX_LENGTH) return { valid: false, message: `Note must be ${MAX_LENGTH} characters or fewer.`, trimmed };\n  return { valid: true, message: \"\", trimmed };\n}\n"
  }
}